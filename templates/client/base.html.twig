<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Creative Studio{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        html { scroll-behavior: smooth; }
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 0;
            padding: 0;
            background:
                radial-gradient(circle at 0% 0%, #312e81 0, transparent 45%),
                radial-gradient(circle at 80% 0%, #0f766e 0, transparent 40%),
                radial-gradient(circle at 10% 80%, #4c1d95 0, transparent 45%),
                #020617;
            color: #e5e7eb;
        }
        header, footer {
            padding: 1.1rem 2rem;
            background: linear-gradient(to bottom, rgba(15,23,42,0.96), rgba(15,23,42,0.82));
            backdrop-filter: blur(22px);
            position: sticky;
            top: 0;
            z-index: 20;
            box-shadow: 0 14px 40px rgba(15,23,42,0.9);
        }
        main { padding: 2rem 1.5rem 3rem; max-width: 1120px; margin: 0 auto; }
        a { color: #38bdf8; text-decoration: none; }
        a:hover { color: #7dd3fc; }
        nav { display: flex; align-items: center; justify-content: space-between; max-width: 1120px; margin: 0 auto; }
        .nav-left { display: flex; align-items: center; gap: 1.5rem; }
        .logo { display: flex; align-items: center; gap: .75rem; font-weight: 800; letter-spacing: .12em; font-size: .85rem; text-transform: uppercase; color: #e5e7eb; position: relative; }
        .logo span { color: #38bdf8; }
        .client-logo {
            height: 40px;
            width: auto;
            display: block;
            filter:
                drop-shadow(0 0 16px rgba(56,189,248,0.8))
                drop-shadow(0 0 32px rgba(56,189,248,0.45))
                brightness(1.35);
        }
        .nav-links a {
            margin-right: 1rem;
            font-weight: 600;
            font-size: 0.95rem;
            color: #e5e7eb;
            padding: 0.5rem 0.9rem;
            border-radius: 999px;
            background: rgba(2, 6, 23, 0.35);
            border: 1px solid rgba(31, 41, 55, 0.7);
            transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
            display: inline-flex;
            align-items: center;
        }
        .nav-links a:last-child { margin-right: 0; }
        .nav-links a:hover {
            transform: translateY(-1px);
            background: rgba(15, 23, 42, 0.8);
            border-color: rgba(56, 189, 248, 0.45);
            color: #ffffff;
        }
        .nav-links a.is-active {
            background: linear-gradient(to right, rgba(56,189,248,0.22), rgba(99,102,241,0.22));
            border-color: rgba(56,189,248,0.65);
            color: #ffffff;
            box-shadow: 0 0 0 1px rgba(56,189,248,0.2), 0 10px 28px rgba(56,189,248,0.2);
        }
        .nav-links a:focus-visible {
            outline: 3px solid rgba(56, 189, 248, 0.35);
            outline-offset: 2px;
        }
        a:focus-visible, .btn:focus-visible, button:focus-visible {
            outline: 3px solid rgba(56, 189, 248, 0.35);
            outline-offset: 2px;
        }
        .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.55rem 1.4rem; border-radius: 999px; border: 1px solid transparent; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all .18s ease-out; }
        .btn-primary { background: linear-gradient(to right, #38bdf8, #6366f1); color: white; box-shadow: 0 18px 45px rgba(56,189,248,0.35); }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 24px 60px rgba(37,99,235,0.45); }
        .btn-ghost { background: transparent; border-color: #1f2937; color: #e5e7eb; }
        .btn-ghost:hover { background: rgba(15,23,42,0.9); }
        .btn-link {
            border: none;
            background: transparent;
            color: #38bdf8;
            cursor: pointer;
            padding: 0;
            font: inherit;
        }
        .btn-link:hover { color: #7dd3fc; }
        .hero { display: grid; grid-template-columns: minmax(0, 3fr) minmax(0, 2.2fr); gap: 1.75rem; align-items: center; margin-bottom: 2.25rem; }
        .hero-text h1 { font-size: clamp(2.3rem, 3.2vw, 3rem); line-height: 1.1; margin-bottom: 1rem; }
        .hero-text p { color: #9ca3af; max-width: 34rem; font-size: 0.98rem; }
        .hero-tag { display: inline-flex; align-items: center; gap: .5rem; padding: .25rem .7rem; border-radius: 999px; background: rgba(15,23,42,0.9); border: 1px solid rgba(56,189,248,0.4); color: #bae6fd; font-size: 0.75rem; margin-bottom: .8rem; }
        .hero-actions { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 1.4rem; }
        .hero-meta { display: flex; flex-wrap: wrap; gap: 1.25rem; margin-top: 1.5rem; font-size: 0.8rem; color: #9ca3af; }
        .hero-badge { padding: 0.45rem 0.8rem; border-radius: 999px; background: rgba(15,23,42,0.85); border: 1px solid #1e293b; font-size: 0.8rem; }
        .hero-visual { position: relative; min-height: 230px; }
        .hero-orbit {
            position: absolute;
            inset: 0;
            margin-left: auto;
            max-width: 340px;
            border-radius: 1.4rem;
            border: 1px solid rgba(148,163,184,0.35);
            background:
                radial-gradient(circle at 0% 0%, rgba(129,140,248,0.55), transparent 55%),
                radial-gradient(circle at 100% 100%, rgba(45,212,191,0.55), transparent 55%),
                rgba(15,23,42,0.9);
            box-shadow: 0 32px 90px rgba(15,23,42,0.95);
            overflow: hidden;
            backdrop-filter: blur(20px);
        }
        .hero-panel-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.65rem 0.95rem;
            border-bottom: 1px solid rgba(148,163,184,0.18);
            font-size: 0.8rem;
            color: #9ca3af;
        }
        .hero-panel-dots { letter-spacing: 0.18em; font-size: 0.75rem; opacity: 0.85; }
        .hero-panel-body {
            padding: 0.85rem 0.95rem 0.95rem;
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            font-size: 0.82rem;
            max-height: 260px;
            overflow-y: auto;
        }
        .hero-panel-body::-webkit-scrollbar {
            width: 6px;
        }
        .hero-panel-body::-webkit-scrollbar-track {
            background: rgba(15,23,42,0.8);
        }
        .hero-panel-body::-webkit-scrollbar-thumb {
            background: rgba(148,163,184,0.6);
            border-radius: 999px;
        }
        .pill {
            border-radius: 0.9rem;
            background: rgba(15,23,42,0.96);
            border: 1px solid rgba(148,163,184,0.5);
            padding: 0.7rem 0.8rem;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        }
        .pill small { display: block; font-size: 0.7rem; color: #9ca3af; }
        .hero-panel-item strong { display: block; font-size: 0.82rem; color: #e5e7eb; font-weight: 650; }
        .hero-panel-item small { margin-top: 0.15rem; }
        .card { background: radial-gradient(circle at top left, rgba(56,189,248,0.08), rgba(15,23,42,0.96)); border-radius: 1rem; padding: 1.5rem 1.6rem; margin-bottom: 1.5rem; border: 1px solid #1f2937; box-shadow: 0 18px 55px rgba(15,23,42,0.9); }
        .card h2, .card h1 { margin-top: 0; margin-bottom: 0.75rem; }
        .card p { color: #9ca3af; font-size: 0.95rem; }
        .section-title { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem; }
        .section-title small { font-size: 0.8rem; color: #6b7280; }
        .grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); }
        .service-pill { font-size: 0.8rem; color: #a5b4fc; }
        .subtle { font-size: 0.86rem; color: #9ca3af; }
        .work-grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); margin-top: 0.5rem; }
        .work-card { position: relative; border-radius: 1rem; padding: 1rem 1.1rem 1.1rem; background: radial-gradient(circle at top, rgba(56,189,248,0.12), rgba(15,23,42,0.98)); border: 1px solid #1f2937; overflow: hidden; }
        .work-card, .service-card, .process-step, .stat-pill {
            transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
        }
        .work-card:hover, .service-card:hover, .process-step:hover, .stat-pill:hover {
            transform: translateY(-2px);
            border-color: rgba(56,189,248,0.5);
            box-shadow: 0 16px 34px rgba(15,23,42,0.55);
        }
        .work-card-thumb { height: 110px; border-radius: 0.8rem; margin-bottom: 0.8rem; background: radial-gradient(circle at 0% 0%, rgba(56,189,248,0.35), transparent 55%), radial-gradient(circle at 100% 100%, rgba(129,140,248,0.45), transparent 60%); opacity: 0.85; }
        .work-card h3 { margin: 0 0 0.3rem; font-size: 1rem; }
        .work-card p { font-size: 0.86rem; margin: 0; color: #9ca3af; }
        .service-grid { display: grid; gap: 1.1rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); margin-top: 0.75rem; }
        .service-card { border-radius: 1rem; padding: 1.1rem 1.2rem 1.2rem; background: rgba(15,23,42,0.98); border: 1px solid #1f2937; }
        .service-card h3 { margin-top: 0; margin-bottom: 0.3rem; font-size: 0.98rem; }
        .service-meta { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 0.4rem; font-size: 0.75rem; color: #9ca3af; }
        .pill-small { padding: 0.2rem 0.65rem; border-radius: 999px; border: 1px solid #1f2937; background: rgba(15,23,42,0.9); }
        .service-card ul { margin: 0.4rem 0 0.7rem; padding-left: 1.1rem; font-size: 0.82rem; color: #9ca3af; }
        .service-card li { margin-bottom: 0.2rem; }
        .service-card .btn { padding-inline: 1rem; font-size: 0.8rem; }
        .process-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-top: 0.75rem; }
        .process-step { border-radius: 0.9rem; padding: 1rem 1rem 1.1rem; background: rgba(15,23,42,0.98); border: 1px solid #1f2937; font-size: 0.85rem; }
        .process-step-number { display: inline-flex; align-items: center; justify-content: center; width: 1.8rem; height: 1.8rem; border-radius: 999px; background: #020617; border: 1px solid #1f2937; font-size: 0.78rem; margin-bottom: 0.55rem; }
        .process-step strong { display: block; margin-bottom: 0.15rem; }
        .brief-layout { display: grid; gap: 1.5rem; grid-template-columns: minmax(0, 2.3fr) minmax(0, 2.4fr); align-items: flex-start; margin-top: 1rem; }
        .stat-pills { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.8rem; }
        .stat-pill { padding: 0.55rem 0.9rem; border-radius: 0.8rem; background: rgba(15,23,42,0.98); border: 1px solid #1f2937; font-size: 0.8rem; }
        .stat-pill span { display: block; font-size: 0.72rem; color: #9ca3af; }
        .progress-shell { margin-top: 0.8rem; }
        .progress-label { display: flex; justify-content: space-between; font-size: 0.78rem; color: #9ca3af; margin-bottom: 0.3rem; }
        .progress-bar { position: relative; height: 0.35rem; border-radius: 999px; background: #020617; overflow: hidden; }
        .progress-bar-fill { position: absolute; inset: 0; width: 70%; background: linear-gradient(to right, #22c55e, #38bdf8); }
        label { display: block; margin-bottom: 0.25rem; font-size: 0.85rem; color: #9ca3af; }
        input, textarea { width: 100%; padding: 0.6rem 0.75rem; border-radius: 0.6rem; border: 1px solid #1e293b; background: #020617; color: #e5e7eb; box-sizing: border-box; font-size: 0.9rem; }
        input:focus, textarea:focus { outline: none; border-color: #38bdf8; box-shadow: 0 0 0 1px #38bdf8; }
        button { padding: 0.6rem 1.25rem; border-radius: 999px; border: none; background: linear-gradient(to right, #38bdf8, #6366f1); color: white; font-weight: 600; cursor: pointer; font-size: 0.9rem; }
        .error { color: #f97373; font-size: 0.8rem; margin-top: 0.25rem; }
        .flash-success { background: #166534; border-radius: 0.6rem; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid #14532d; }
        .flash-error { background: rgba(185, 28, 28, 0.25); border-radius: 0.6rem; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid rgba(248, 113, 113, 0.35); }
        footer { font-size: 0.8rem; color: #6b7280; text-align: center; border-top: 1px solid #111827; }
        @media (max-width: 768px) {
            .hero { grid-template-columns: minmax(0, 1fr); }
            .hero-visual { min-height: 280px; }
            .hero-orbit { max-width: 100%; margin: 0; }
            .brief-layout { grid-template-columns: 1fr; }
            .section-title { flex-direction: column; align-items: flex-start; gap: 0.35rem; }
            header, footer { padding-inline: 1.25rem; }
            main { padding-inline: 1.25rem; }
            nav { flex-wrap: wrap; gap: 0.8rem; }
            .nav-left { width: 100%; justify-content: space-between; }
            .nav-links { display: none; }
        }
    </style>
</head>
<body>
<header>
    <nav>
            {% set activeRoute = app.request.attributes.get('_route') %}
            <div class="nav-left">
                <div class="logo">
                    <img src="{{ asset('images/client-logo.png') }}" alt="Campana Designs logo" class="client-logo">
                    
                </div>
            <div class="nav-links">
                <a href="{{ path('client_landing') }}" class="{{ activeRoute in ['client_landing', 'app_client_dashboard'] ? 'is-active' : '' }}" {{ activeRoute in ['client_landing', 'app_client_dashboard'] ? 'aria-current="page"' : '' }}>Home</a>
                <a href="{{ path('client_services') }}" class="{{ activeRoute in ['client_services', 'client_service_show'] ? 'is-active' : '' }}" {{ activeRoute in ['client_services', 'client_service_show'] ? 'aria-current="page"' : '' }}>Services</a>
                <a href="{{ path('client_about') }}" class="{{ activeRoute == 'client_about' ? 'is-active' : '' }}" {{ activeRoute == 'client_about' ? 'aria-current="page"' : '' }}>About</a>
                <a href="{{ path('client_contact') }}" class="{{ activeRoute == 'client_contact' ? 'is-active' : '' }}" {{ activeRoute == 'client_contact' ? 'aria-current="page"' : '' }}>Contact</a>
            </div>
        </div>
        <div>
            {% if app.user is not null and 'ROLE_CLIENT' in app.user.roles %}
                <a href="{{ path('client_profile') }}" class="btn btn-ghost">Profile</a>
                <a href="{{ path('app_logout') }}" class="btn btn-primary" style="margin-left:0.5rem;">Log out</a>
            {% else %}
                <a href="{{ path('app_login_index', { next: app.request.pathInfo }) }}" class="btn btn-ghost">Log in</a>
            {% endif %}
        </div>
    </nav>
</header>

<main>
    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash-error">{{ message }}</div>
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer>
    <div style="max-width: 1120px; margin: 0 auto; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:0.75rem;">
        <small>&copy; {{ "now"|date("Y") }} Your Creative Studio. All rights reserved.</small>
        <div style="font-size:0.8rem; display:flex; gap:0.75rem;">
            <a href="{{ path('client_services') }}">Services</a>
            <a href="{{ path('client_contact') }}">Contact</a>
            <span style="color:#4b5563;">Portfolio crafted in Symfony.</span>
        </div>
    </div>
</footer>
</body>
</html>

