{% extends 'client/base.html.twig' %}

{% block title %}Contact Me{% endblock %}

{% block body %}
    <section class="card">
        <h1>Contact Me</h1>
        <p>Have a project in mind? Send a message with a few details and I’ll get back to you as soon as possible.</p>

        <form method="post" action="{{ path('client_contact') }}">
            <div style="margin-bottom: 1rem;">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" value="{{ form_data.name|default('') }}">
                {% if errors.name is defined %}
                    <div class="error">{{ errors.name }}</div>
                {% endif %}
            </div>

            <div style="margin-bottom: 1rem;">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="{{ form_data.email|default('') }}">
                {% if errors.email is defined %}
                    <div class="error">{{ errors.email }}</div>
                {% endif %}
            </div>

            <div style="margin-bottom: 1rem;">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" value="{{ form_data.subject|default('') }}">
                {% if errors.subject is defined %}
                    <div class="error">{{ errors.subject }}</div>
                {% endif %}
            </div>

            <div style="margin-bottom: 1rem;">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="5">{{ form_data.message|default('') }}</textarea>
                {% if errors.message is defined %}
                    <div class="error">{{ errors.message }}</div>
                {% endif %}
            </div>

            <button type="submit">Send Message</button>
            <p class="subtle" style="margin-top: 0.55rem;">
                Messages are delivered via our secure email provider for faster response.
            </p>
            <p style="margin-top: 0.75rem; font-size: 0.8rem; color: #6b7280;">
                Already a client? You can also
                <a href="{{ path('app_login_index', { next: app.request.pathInfo }) }}">log in</a> to track your orders.
            </p>
        </form>
    </section>
{% endblock %}

