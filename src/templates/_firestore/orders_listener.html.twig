<script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-firestore-compat.js"></script>
<script>
(function () {
    const firebaseConfig = window.__FIREBASE_CONFIG__ || {{ firebase_web_config|json_encode(constant('JSON_HEX_TAG'))|raw }};
    const tokenUrl = '{{ path('firebase_custom_token_web') }}';

    if (!firebaseConfig || !firebaseConfig.apiKey || firebaseConfig.apiKey === '') {
        console.warn('[firestore] Firebase web config missing (set FIREBASE_WEB_* on server). Realtime orders disabled.');
        return;
    }

    if (!firebaseConfig.projectId || firebaseConfig.projectId === '') {
        console.warn('[firestore] FIREBASE_WEB_PROJECT_ID missing. Use project id: cdappdev');
        return;
    }

    let unsubscribe = null;
    let dataTable = null;
    let listenerReady = false;

    const showToast = (text) => {
        const el = document.createElement('div');
        el.textContent = text;
        el.style.cssText = 'position:fixed;right:16px;bottom:16px;z-index:2000;background:rgba(15,23,42,0.95);color:#e2e8f0;padding:10px 14px;border-radius:8px;border:1px solid rgba(56,189,248,0.45);font-size:13px;';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 2500);
    };

    const formatDelivery = (value) => {
        if (!value) return 'N/A';
        if (typeof value === 'string') return value.slice(0, 10);
        if (value.toDate) return value.toDate().toISOString().slice(0, 10);
        return 'N/A';
    };

    const findRow = (orderId) => {
        return document.querySelector(`#ordersTable tbody tr[data-order-id="${orderId}"]`);
    };

    const applyOrderUpdate = (order) => {
        const orderId = String(order.id ?? '');
        if (!orderId) return;

        const row = findRow(orderId);
        if (!row) {
            showToast(`New order #${orderId} — refreshing list.`);
            window.location.reload();
            return;
        }

        const cells = row.querySelectorAll('td');
        if (cells.length >= 6) {
            cells[4].textContent = order.status || 'N/A';
            cells[5].textContent = formatDelivery(order.deliveryDate);
        }

        if (dataTable) {
            dataTable.row(row).invalidate('dom');
        }

        showToast(`Order #${orderId} updated (${order.status || 'N/A'}).`);
    };

    const removeOrderRow = (orderId) => {
        const row = findRow(orderId);
        if (!row || !dataTable) return;
        dataTable.row(row).remove().draw(false);
        showToast(`Order #${orderId} removed.`);
    };

    const attachListener = async () => {
        if (listenerReady) return;

        try {
            const res = await fetch(tokenUrl, { credentials: 'include', headers: { Accept: 'application/json' } });
            const json = await res.json();
            if (!res.ok || !json.success || !json.token) {
                throw new Error(json.message || 'Could not get Firebase custom token (check FIREBASE_CREDENTIALS_JSON on server).');
            }

            if (!firebase.apps.length) {
                firebase.initializeApp(firebaseConfig);
            }

            await firebase.auth().signInWithCustomToken(json.token);
            const db = firebase.firestore();

            let isFirstSnapshot = true;
            unsubscribe = db.collection('orders').onSnapshot(
                (snapshot) => {
                    if (isFirstSnapshot) {
                        isFirstSnapshot = false;
                        console.info('[firestore] Orders listener connected (' + snapshot.size + ' docs).');
                        return;
                    }

                    snapshot.docChanges().forEach((change) => {
                        const orderId = change.doc.id;
                        if (change.type === 'removed') {
                            removeOrderRow(orderId);
                            return;
                        }
                        applyOrderUpdate(change.doc.data());
                    });
                },
                (error) => {
                    console.error('[firestore] Listener error:', error);
                    showToast('Realtime connection error — check browser console.');
                }
            );

            listenerReady = true;
        } catch (error) {
            console.warn('[firestore] Could not start orders listener:', error);
            showToast('Realtime unavailable: ' + (error.message || 'see console'));
        }
    };

    const boot = () => {
        const tableEl = document.getElementById('ordersTable');
        if (!tableEl || !window.jQuery || !window.jQuery.fn.dataTable) {
            setTimeout(boot, 100);
            return;
        }

        const $ = window.jQuery;
        if ($.fn.DataTable.isDataTable('#ordersTable')) {
            dataTable = $('#ordersTable').DataTable();
        } else {
            dataTable = $('#ordersTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: true,
                pageLength: 10,
                lengthMenu: [5, 10, 20, 50],
                order: [[0, 'desc']],
                columnDefs: [{ orderable: false, targets: -1 }],
            });
        }

        attachListener();
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
    } else {
        boot();
    }

    window.addEventListener('beforeunload', () => {
        if (typeof unsubscribe === 'function') {
            unsubscribe();
        }
    });
})();
</script>
