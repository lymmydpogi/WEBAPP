{% extends 'ADMIN/base.html.twig' %}

{% block title %}Order Index{% endblock %}
{% block page_title %}Orders{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('style/css/ORDER/order.css') }}">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="hero-section">
    <h1>Order Management Dashboard</h1>
    <p>Track, manage, and process all customer orders efficiently from a single centralized interface.</p>
</section>

<!-- Flash Messages -->
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    title: '{{ label|capitalize }}',
                    text: '{{ message }}',
                    icon: '{{ label == "success" ? "success" : "error" }}',
                    confirmButtonText: 'OK',
                });
            });
        </script>
    {% endfor %}
{% endfor %}

<!-- Order Table Section -->
<section class="order-table-section">
    <h2 class="section-title">All Orders</h2>

    <div class="btn-container mb-3">
        <a href="{{ path('app_order_new') }}" class="btn-create">
            <span>+</span> Create New Order
        </a>
    </div>

    <div class="table-container">
        <table class="table" id="ordersTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Client Name</th>
                    <th>Client Email</th>
                    <th>Service</th>
                    <th>Status</th>
                    <th>Delivery Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for order in orders %}
                    <tr id="order-row-{{ order.id }}" data-order-id="{{ order.id }}">
                        <td>{{ order.id }}</td>
                        <td>{{ order.user ? order.user.name ?: 'Unnamed User' : order.clientName ?: 'N/A' }}</td>
                        <td>{{ order.user ? order.user.email : order.clientEmail ?: 'N/A' }}</td>
                        <td>{{ order.service ? order.service.name : 'N/A' }}</td>
                        <td>{{ order.status }}</td>
                        <td>{{ order.deliveryDate ? order.deliveryDate|date('Y-m-d') : 'N/A' }}</td>
                        <td>
                            {% include 'ADMIN/_TABLES/order/_poll_actions.html.twig' with { order: order } %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="empty-state text-center py-4">No orders found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>

{% endblock %}
