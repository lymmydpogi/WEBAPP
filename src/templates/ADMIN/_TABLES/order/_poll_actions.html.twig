<a href="{{ path('app_order_show', {'id': order.id}) }}" class="btn-show">Show</a>
<a href="{{ path('app_order_edit', {'id': order.id}) }}" class="btn-edit">Edit</a>
{% if order.status == 'Completed' %}
    <a href="{{ path('app_order_receipt', {'id': order.id}) }}" class="btn-receipt">Receipt</a>
{% endif %}
<form method="post" action="{{ path('app_order_delete', {'id': order.id}) }}" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this order?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
    <button type="submit" class="btn-delete">Delete</button>
</form>
