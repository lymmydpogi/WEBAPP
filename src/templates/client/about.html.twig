{% extends 'client/base.html.twig' %}

{% block title %}About Us{% endblock %}

{% block body %}
    <section class="hero">
        <div class="hero-text">
            <div class="hero-tag">
                <span>About Us</span>
            </div>
            <h1>Built through collaboration and shared expertise.</h1>
            <p>
                This website was created through the collaboration of a dedicated team, each contributing their expertise to bring the idea to life.
            </p>
            <div class="hero-meta">
                <span class="hero-badge">Professional</span>
                <span class="hero-badge">Collaborative</span>
                <span class="hero-badge">User-focused</span>
            </div>
        </div>

        <div class="hero-visual">
            <div class="hero-orbit">
                <div class="hero-panel-top">
                    <span class="hero-panel-dots">● ● ●</span>
                    <span>Team Overview</span>
                </div>
                <div class="hero-panel-body">
                    <div class="pill hero-panel-item">
                        <strong>Project Leadership</strong>
                        <small>Clear direction from concept to launch</small>
                    </div>
                    <div class="pill hero-panel-item">
                        <strong>Backend Development</strong>
                        <small>Reliable logic and system functionality</small>
                    </div>
                    <div class="pill hero-panel-item">
                        <strong>Frontend Development</strong>
                        <small>Clean interface and smooth user experience</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="section-title">
            <h2>Our Team</h2>
            <small>The people behind the website.</small>
        </div>
        <div class="work-grid">
            <article class="work-card">
                <h3>Lymwel Angelho Campana</h3>
                <div class="service-meta">
                    <span class="pill-small">Project Lead / Idea Creator</span>
                </div>
                <p>The visionary behind the concept and overall direction of the website.</p>
            </article>

            <article class="work-card">
                <h3>Rodge Vallejera</h3>
                <div class="service-meta">
                    <span class="pill-small">Backend Developer</span>
                </div>
                <p>Responsible for server-side logic, database management, and system functionality.</p>
            </article>

            <article class="work-card">
                <h3>Kurt Mendrick Tatoy</h3>
                <div class="service-meta">
                    <span class="pill-small">Frontend Developer</span>
                </div>
                <p>Handled the user interface and user experience, ensuring a smooth and engaging design.</p>
            </article>
        </div>
    </section>

    <section class="card" style="text-align:center; padding:2rem 1.6rem;">
        <h2 style="margin-bottom:0.55rem;">Working as one team</h2>
        <p style="margin-bottom:1rem;">
            Together, the team worked collaboratively to design and develop a functional and user-friendly website.
        </p>
        <a href="{{ path('client_contact') }}" class="btn btn-primary">Contact Us</a>
    </section>
{% endblock %}

