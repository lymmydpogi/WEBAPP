{% extends 'client/base.html.twig' %}

{% block title %}My orders{% endblock %}

{% block body %}
    <section class="card">
        <div class="section-title">
            <h1>My orders</h1>
            <small>Track your project requests and manage pending orders.</small>
        </div>

        {% if orders is empty %}
            <div class="orders-empty">
                <div class="orders-empty__icon" aria-hidden="true">📋</div>
                <h2>No orders yet</h2>
                <p>When you submit a project brief from a service page, your request will show up here so you can track status and updates.</p>
                <a href="{{ path('client_services') }}" class="btn btn-primary">Browse services</a>
            </div>
        {% else %}
            <div class="order-list">
                {% for order in orders %}
                    <article class="order-list-item">
                        <div>
                            <strong>#{{ order.id }} — {{ order.service ? order.service.name : 'Service' }}</strong>
                            <p class="subtle">
                                {{ order.orderDate ? order.orderDate|date('M d, Y') : '' }}
                                · ₱{{ order.totalPrice|number_format(2) }}
                            </p>
                            <span class="pill-small order-status order-status--{{ order.status|lower|replace({' ': '-'}) }}">{{ order.status }}</span>
                        </div>
                        <div class="order-list-actions">
                            <a href="{{ path('client_order_show', { id: order.id }) }}" class="btn btn-ghost">View</a>
                            {% if order.status == 'Pending' %}
                                <a href="{{ path('client_order_edit', { id: order.id }) }}" class="btn btn-ghost">Edit</a>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    <style>
        .orders-empty {
            margin-top: 1.25rem;
            padding: 2.5rem 1.75rem;
            text-align: center;
            border-radius: 1rem;
            border: 1px dashed rgba(56, 189, 248, 0.35);
            background: linear-gradient(160deg, rgba(15, 23, 42, 0.9), rgba(30, 27, 75, 0.55));
        }
        .orders-empty__icon { font-size: 2.5rem; margin-bottom: 0.75rem; opacity: 0.85; }
        .orders-empty h2 { margin: 0 0 0.5rem; font-size: 1.35rem; color: #f9fafb; }
        .orders-empty p {
            margin: 0 auto 1.25rem;
            max-width: 42ch;
            color: #9ca3af;
            font-size: 0.95rem;
            line-height: 1.55;
        }
        .order-list { display: flex; flex-direction: column; gap: 0.85rem; margin-top: 1rem; }
        .order-list-item {
            display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 0.75rem;
            padding: 1rem 1.1rem; border-radius: 0.85rem; border: 1px solid #1f2937;
            background: rgba(15,23,42,0.85);
        }
        .order-list-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
        .order-status { margin-top: 0.45rem; display: inline-block; }
        .order-status--pending { border-color: rgba(56,189,248,0.5); color: #bae6fd; }
        .order-status--approved { border-color: rgba(34,197,94,0.45); color: #bbf7d0; }
        .order-status--in-progress { border-color: rgba(250,204,21,0.45); color: #fef08a; }
        .order-status--completed { border-color: rgba(99,102,241,0.45); color: #c7d2fe; }
        .order-status--cancelled { border-color: rgba(248,113,113,0.45); color: #fecaca; }
        .order-status--rejected { border-color: rgba(248,113,113,0.55); color: #fca5a5; }
    </style>
{% endblock %}
