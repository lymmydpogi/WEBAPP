{# Inline assets: production was 404 on /js/admin-live.js — script ships with every HTML response #}
<style>
#ordersTable.admin-live-flash {
    outline: 2px solid rgba(56, 189, 248, 0.45);
    outline-offset: 2px;
    transition: outline-color 0.4s ease;
}
.admin-live-status {
    position: fixed;
    left: 12px;
    bottom: 12px;
    z-index: 9998;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    pointer-events: none;
    box-shadow: 0 0 0 2px rgba(15, 23, 42, 0.35);
}
.admin-live-status--on {
    background: #22c55e;
    animation: admin-live-pulse 2s ease-in-out infinite;
}
.admin-live-status--off {
    background: #ef4444;
}
@keyframes admin-live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
}

/* Full-width activity banners (below top navbar) */
.admin-live-banner-stack {
    position: fixed;
    top: 70px;
    left: 280px;
    right: 0;
    z-index: 10050;
    display: flex;
    flex-direction: column;
    gap: 0;
    pointer-events: none;
}

.admin-live-banner {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 20px;
    min-height: 52px;
    color: #fff;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.2);
    animation: admin-live-banner-in 0.3s ease-out;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
}

.admin-live-banner--order {
    background: linear-gradient(90deg, #0369a1 0%, #0284c7 100%);
}

.admin-live-banner--message {
    background: linear-gradient(90deg, #6d28d9 0%, #7c3aed 100%);
}

.admin-live-banner--login {
    background: linear-gradient(90deg, #5b21b6 0%, #7c3aed 100%);
}

.admin-live-banner--order-update {
    background: linear-gradient(90deg, #b45309 0%, #d97706 100%);
}

.admin-live-banner__icon {
    font-size: 1.35rem;
    flex-shrink: 0;
    line-height: 1;
}

.admin-live-banner__content {
    flex: 1;
    min-width: 0;
}

.admin-live-banner__title {
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.92;
    margin-bottom: 2px;
}

.admin-live-banner__message {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.admin-live-banner__action {
    flex-shrink: 0;
    padding: 8px 14px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    transition: background 0.15s ease;
}

.admin-live-banner__action:hover {
    background: rgba(255, 255, 255, 0.32);
    color: #fff;
}

.admin-live-banner__close {
    flex-shrink: 0;
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    padding: 4px 8px;
}

.admin-live-banner__close:hover {
    color: #fff;
}

body.admin-live-banners-visible .main-content {
    transition: margin-top 0.2s ease;
}

@keyframes admin-live-banner-in {
    from {
        opacity: 0;
        transform: translateY(-100%);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 768px) {
    .admin-live-banner-stack {
        left: 0;
    }
}

body.dark-mode .admin-live-banner {
    border-bottom-color: rgba(255, 255, 255, 0.08);
}
</style>
<div id="admin-live-banner-stack" class="admin-live-banner-stack" aria-live="polite" aria-relevant="additions"></div>
<script>
{% include '_polling/admin_live.script.js.twig' %}
</script>
