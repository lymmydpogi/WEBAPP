{# Live updates for admin staff — polls MySQL every 500ms, no page refresh. #}
<script>
(function () {
    const ORDERS_URL = '{{ url('admin_live_orders') }}';
    const DASHBOARD_URL = '{{ url('admin_live_dashboard') }}';
    const ORDERS_PAGE_URL = '{{ url('app_order_index') }}';
    const POLL_MS = 500;

    const ordersTable = document.getElementById('ordersTable');
    const hasDashboard = Boolean(document.getElementById('live-stat-pending-orders'));

    let ordersRevision = null;
    let dashboardRevision = null;
    let ordersTimer = null;
    let dashboardTimer = null;
    let ordersInFlight = false;
    let dashboardInFlight = false;

    const formatRevenue = (value) => {
        const amount = Number(value) || 0;
        return '₱' + amount.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    };

    const fetchJson = async (baseUrl) => {
        const response = await fetch(baseUrl + (baseUrl.includes('?') ? '&' : '?') + '_=' + Date.now(), {
            method: 'GET',
            credentials: 'same-origin',
            headers: {
                Accept: 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
            },
            cache: 'no-store',
        });

        if (!response.ok) {
            return null;
        }

        const type = response.headers.get('content-type') || '';
        if (!type.includes('json')) {
            return null;
        }

        return response.json();
    };

    const showNewOrderToast = (count) => {
        if (ordersTable) {
            return;
        }

        let el = document.getElementById('admin-live-toast');
        if (!el) {
            el = document.createElement('div');
            el.id = 'admin-live-toast';
            el.style.cssText = 'position:fixed;right:16px;bottom:16px;z-index:9999;background:#0f172a;color:#e2e8f0;padding:12px 16px;border-radius:10px;border:1px solid rgba(56,189,248,0.5);font-size:14px;box-shadow:0 8px 24px rgba(0,0,0,0.35);max-width:280px;';
            document.body.appendChild(el);
        }

        el.innerHTML = 'Orders updated (' + count + ' total). <a href="' + ORDERS_PAGE_URL + '" style="color:#38bdf8;margin-left:6px;">View orders</a>';
        el.style.display = 'block';
        setTimeout(() => { el.style.display = 'none'; }, 4000);
    };

    const renderOrdersTable = (orders) => {
        if (!ordersTable) {
            return;
        }

        const tbody = ordersTable.querySelector('tbody');
        if (!tbody) {
            return;
        }

        tbody.innerHTML = '';

        if (!orders.length) {
            const empty = document.createElement('tr');
            empty.innerHTML = '<td colspan="7" class="empty-state text-center py-4">No orders found.</td>';
            tbody.appendChild(empty);
            return;
        }

        orders.forEach((order) => {
            const tr = document.createElement('tr');
            tr.id = 'order-row-' + order.id;
            tr.setAttribute('data-order-id', String(order.id));

            [
                String(order.id),
                order.clientName || 'N/A',
                order.clientEmail || 'N/A',
                order.serviceName || 'N/A',
                order.status || 'N/A',
                order.deliveryDate || 'N/A',
            ].forEach((value) => {
                const td = document.createElement('td');
                td.textContent = value;
                tr.appendChild(td);
            });

            const actions = document.createElement('td');
            actions.innerHTML = order.actionsHtml || '';
            tr.appendChild(actions);

            tbody.appendChild(tr);
        });

        ordersTable.classList.add('admin-live-flash');
        setTimeout(() => ordersTable.classList.remove('admin-live-flash'), 600);
    };

    const pollOrders = async () => {
        if (ordersInFlight || document.visibilityState === 'hidden') {
            return;
        }

        ordersInFlight = true;
        try {
            const payload = await fetchJson(ORDERS_URL);
            if (!payload || !payload.success) {
                return;
            }

            const revision = String(payload.revision || '');
            const orders = Array.isArray(payload.orders) ? payload.orders : [];

            if (ordersRevision === null) {
                ordersRevision = revision;
                return;
            }

            if (revision === ordersRevision) {
                return;
            }

            renderOrdersTable(orders);
            showNewOrderToast(payload.count || orders.length);
            ordersRevision = revision;
        } finally {
            ordersInFlight = false;
        }
    };

    const pollDashboard = async () => {
        if (!hasDashboard || dashboardInFlight || document.visibilityState === 'hidden') {
            return;
        }

        dashboardInFlight = true;
        try {
            const data = await fetchJson(DASHBOARD_URL);
            if (!data || !data.success) {
                return;
            }

            const revision = String(data.revision || '');

            if (dashboardRevision === null) {
                dashboardRevision = revision;
                return;
            }

            if (revision === dashboardRevision) {
                return;
            }

            const activeEl = document.getElementById('live-stat-active-services');
            const pendingEl = document.getElementById('live-stat-pending-orders');
            const usersEl = document.getElementById('live-stat-total-users');
            const revenueEl = document.getElementById('live-stat-monthly-revenue');

            if (activeEl) activeEl.textContent = String(data.activeServices ?? 0);
            if (pendingEl) pendingEl.textContent = String(data.pendingOrders ?? 0);
            if (usersEl) usersEl.textContent = String(data.totalUsers ?? 0);
            if (revenueEl) revenueEl.textContent = formatRevenue(data.monthlyRevenue);

            dashboardRevision = revision;
        } finally {
            dashboardInFlight = false;
        }
    };

    const start = () => {
        void pollOrders();
        ordersTimer = setInterval(pollOrders, POLL_MS);

        if (hasDashboard) {
            void pollDashboard();
            dashboardTimer = setInterval(pollDashboard, POLL_MS);
        }
    };

    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') {
            void pollOrders();
            void pollDashboard();
        }
    });

    start();

    window.addEventListener('beforeunload', () => {
        if (ordersTimer) clearInterval(ordersTimer);
        if (dashboardTimer) clearInterval(dashboardTimer);
    });
})();
</script>
<style>
    #ordersTable.admin-live-flash {
        outline: 2px solid rgba(56, 189, 248, 0.45);
        outline-offset: 2px;
        transition: outline-color 0.4s ease;
    }
</style>
