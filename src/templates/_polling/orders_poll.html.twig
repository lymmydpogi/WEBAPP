<script>
(function () {
    const pollUrl = '{{ path('app_order_poll') }}';
    const POLL_MS = 4000;
    let dataTable = null;
    let pollTimer = null;
    let baseline = null;
    let isPolling = false;

    const rowIdsOnPage = () => {
        const ids = [];
        document.querySelectorAll('#ordersTable tbody tr[data-order-id]').forEach((row) => {
            const id = row.getAttribute('data-order-id');
            if (id) {
                ids.push(String(id));
            }
        });
        return ids;
    };

    const fingerprint = (orders) => {
        return orders
            .map((o) => `${o.id}|${o.status}|${o.deliveryDate}|${o.clientName}|${o.serviceName}`)
            .join(';;');
    };

    const applyOrderUpdates = (orders) => {
        orders.forEach((order) => {
            const row = document.querySelector(`#ordersTable tbody tr[data-order-id="${order.id}"]`);
            if (!row) {
                return;
            }
            const cells = row.querySelectorAll('td');
            if (cells.length < 6) {
                return;
            }
            cells[1].textContent = order.clientName || 'N/A';
            cells[2].textContent = order.clientEmail || 'N/A';
            cells[3].textContent = order.serviceName || 'N/A';
            cells[4].textContent = order.status || 'N/A';
            cells[5].textContent = order.deliveryDate || 'N/A';
        });

        if (dataTable) {
            dataTable.rows().invalidate('dom').draw(false);
        }
    };

    const needsFullReload = (orders) => {
        const serverIds = orders.map((o) => String(o.id));
        const pageIds = rowIdsOnPage();

        if (serverIds.length !== pageIds.length) {
            return true;
        }

        for (let i = 0; i < serverIds.length; i += 1) {
            if (!pageIds.includes(serverIds[i])) {
                return true;
            }
        }

        return false;
    };

    const poll = async () => {
        if (isPolling || document.visibilityState === 'hidden') {
            return;
        }

        isPolling = true;
        try {
            const response = await fetch(pollUrl, {
                method: 'GET',
                credentials: 'same-origin',
                headers: { Accept: 'application/json' },
            });

            if (!response.ok) {
                return;
            }

            const payload = await response.json();
            const orders = Array.isArray(payload.orders) ? payload.orders : [];
            const next = fingerprint(orders);

            if (baseline === null) {
                baseline = next;
                return;
            }

            if (next === baseline) {
                return;
            }

            if (needsFullReload(orders)) {
                window.location.reload();
                return;
            }

            applyOrderUpdates(orders);
            baseline = next;
        } catch (_error) {
            // Ignore network errors; next poll will retry.
        } finally {
            isPolling = false;
        }
    };

    const startPolling = () => {
        if (pollTimer) {
            clearInterval(pollTimer);
        }
        poll();
        pollTimer = setInterval(poll, POLL_MS);
    };

    const boot = () => {
        if (!window.jQuery || !window.jQuery.fn.dataTable) {
            setTimeout(boot, 100);
            return;
        }

        const tableEl = document.getElementById('ordersTable');
        if (!tableEl) {
            return;
        }

        const $ = window.jQuery;
        if ($.fn.DataTable.isDataTable('#ordersTable')) {
            dataTable = $('#ordersTable').DataTable();
        } else {
            dataTable = $('#ordersTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                info: true,
                pageLength: 10,
                lengthMenu: [5, 10, 20, 50],
                order: [[0, 'desc']],
                columnDefs: [{ orderable: false, targets: -1 }],
            });
        }

        startPolling();
    };

    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') {
            poll();
        }
    });

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
    } else {
        boot();
    }

    window.addEventListener('beforeunload', () => {
        if (pollTimer) {
            clearInterval(pollTimer);
        }
    });
})();
</script>
