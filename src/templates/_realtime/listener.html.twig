<script>
(function () {
    const streamUrl = '{{ path('realtime_stream') }}';
    const pollUrl = '{{ path('realtime_events') }}';
    let source = null;
    let retryTimer = null;
    let pollTimer = null;
    let reconnectDelayMs = 3000;
    let lastEventId = Number(localStorage.getItem('realtime_last_event_id') || 0) || 0;

    const isSkippablePath = () => {
        const p = window.location.pathname;
        return p.startsWith('/login') || p.startsWith('/register') || p.startsWith('/realtime/');
    };

    const showRealtimeToast = (text) => {
        const el = document.createElement('div');
        el.textContent = text;
        el.style.position = 'fixed';
        el.style.right = '16px';
        el.style.bottom = '16px';
        el.style.zIndex = '2000';
        el.style.background = 'rgba(15,23,42,0.95)';
        el.style.color = '#e2e8f0';
        el.style.padding = '10px 14px';
        el.style.borderRadius = '8px';
        el.style.border = '1px solid rgba(56,189,248,0.45)';
        el.style.boxShadow = '0 10px 28px rgba(2,6,23,0.45)';
        el.style.fontSize = '13px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 2500);
    };

    const scheduleReconnect = () => {
        if (retryTimer) {
            return;
        }

        retryTimer = setTimeout(() => {
            retryTimer = null;
            connect();
        }, reconnectDelayMs);
    };

    const applyEvent = (eventData) => {
        const payload = typeof eventData === 'string' ? JSON.parse(eventData || '{}') : eventData;
        const id = Number(payload.id || 0);
        if (id > 0) {
            lastEventId = id;
            localStorage.setItem('realtime_last_event_id', String(id));
        }

        const summary = payload?.payload?.summary || 'App data updated.';
        showRealtimeToast(`Realtime update: ${summary}`);

        if (document.visibilityState === 'visible' && !isSkippablePath()) {
            setTimeout(() => window.location.reload(), 700);
        }
    };

    const connect = () => {
        if (source) {
            source.close();
        }

        const url = lastEventId > 0 ? `${streamUrl}?lastEventId=${lastEventId}` : streamUrl;
        source = new EventSource(url, { withCredentials: true });

        source.addEventListener('app.action', (event) => {
            try {
                applyEvent(event.data || '{}');
            } catch (_e) {
                // Ignore malformed realtime payloads.
            }
        });

        source.onerror = () => {
            source?.close();
            source = null;
            scheduleReconnect();
        };
    };

    const poll = async () => {
        try {
            const url = lastEventId > 0 ? `${pollUrl}?lastEventId=${lastEventId}` : pollUrl;
            const res = await fetch(url, { credentials: 'include' });
            if (!res.ok) {
                throw new Error('realtime poll failed');
            }
            const json = await res.json();
            const events = Array.isArray(json?.events) ? json.events : [];
            for (const ev of events) {
                try {
                    applyEvent(ev);
                } catch (_e) {
                    // ignore malformed event
                }
            }
        } catch (_e) {
            // silent: will retry
        } finally {
            pollTimer = setTimeout(poll, reconnectDelayMs);
        }
    };

    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') {
            if (typeof EventSource !== 'undefined' && !source) {
                connect();
            } else if (typeof EventSource === 'undefined' && !pollTimer) {
                poll();
            }
        }
    });

    window.addEventListener('beforeunload', () => {
        source?.close();
        if (retryTimer) {
            clearTimeout(retryTimer);
        }
        if (pollTimer) {
            clearTimeout(pollTimer);
        }
    });

    if (typeof EventSource !== 'undefined') {
        connect();
    } else {
        poll();
    }
})();
</script>
