<!doctype html>
<html lang="en">
    <body style="font-family: system-ui, sans-serif; color: #0f172a; line-height: 1.5;">
        {% if isNewAccount %}
            <h1>Welcome to Campana Designs</h1>
            <p>Hi {{ user.name ?? user.email }},</p>
            <p>Your account was created with Google sign-in. You are signed in and ready to go.</p>
        {% else %}
            <h1>Signed in with Google</h1>
            <p>Hi {{ user.name ?? user.email }},</p>
            <p>You just signed in to Campana Designs with your Google account.</p>
        {% endif %}

        <p>
            <a href="{{ continueUrl }}" style="display: inline-block; padding: 10px 18px; background: #0f172a; color: #fff; text-decoration: none; border-radius: 8px;">
                Continue to your dashboard
            </a>
        </p>
    </body>
</html>
