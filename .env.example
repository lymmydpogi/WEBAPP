# Copy to .env for local development (never commit real secrets).
# On Railway, set these in the service Variables tab.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_generate_with_openssl_rand_hex_16
###< symfony/framework-bundle ###

# Public URL of this backend (used for absolute links in emails)
APP_URL=http://127.0.0.1:8000

###> doctrine/doctrine-bundle ###
# Local MySQL (Symfony CLI / Docker — adjust host/port to your setup)
DATABASE_URL="mysql://app_user:app_password@127.0.0.1:3306/app_db?serverVersion=8.0&charset=utf8mb4"

# Railway MySQL (set by plugin OR built in entrypoint from MYSQL* vars):
# DATABASE_URL is optional if all of these are set:
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
# MYSQL_VERSION=8.0
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
MAILER_FROM_ADDRESS=noreply@example.com
MAILER_FROM_NAME="Campana Studio"
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
# Local: generate with: php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me

# Railway (recommended — persist keys across deploys):
# JWT_PRIVATE_KEY_BASE64=
# JWT_PUBLIC_KEY_BASE64=
# JWT_PASSPHRASE= (leave empty if keys are not passphrase-protected)
###< lexik/jwt-authentication-bundle ###

###> Google OAuth (web admin + mobile) ###
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANDROID_CLIENT_ID=
OAUTH_GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/connect/google/check
###< Google OAuth ###

###> Firebase (web client pages only) ###
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MEASUREMENT_ID=

###> CORS (optional — native mobile does not need CORS) ###
CORS_ALLOWED_ORIGINS=*

###> Railway deploy (production) ###
# APP_ENV=prod
# APP_DEBUG=0
# RUN_MIGRATIONS=1   # set only for first deploy / manual migration run, then unset
# PORT=8080          # set automatically by Railway
