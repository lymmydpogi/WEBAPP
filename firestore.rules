rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      // Clients read their own orders; staff/admin read all (via custom token claims).
      allow read: if request.auth != null
        && (
          resource.data.userId == request.auth.token.campanaUserId
          || 'ROLE_STAFF' in request.auth.token.roles
          || 'ROLE_ADMIN' in request.auth.token.roles
        );
      // Writes only from Firebase Admin SDK (server).
      allow write: if false;
    }
  }
}
